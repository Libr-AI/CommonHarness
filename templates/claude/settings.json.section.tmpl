{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "cat .harness/CURRENT.md 2>/dev/null && echo '---' && cat AGENTS.md 2>/dev/null | head -60"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-harness-state.sh"
          }
        ]
      }
    ]
  }
}
